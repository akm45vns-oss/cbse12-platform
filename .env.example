# ==========================================
# AkmEdu Enterprise Platform - Environment Variables
# ==========================================

# 1. FRONTEND CONFIGURATION (Vite)
# The Supabase URL for public/client-side data fetching (if applicable)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# The Supabase Anon key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 2. BACKEND CONFIGURATION (Node.js/Express)
# Server Port
PORT=5000
# Environment (development, production, test)
NODE_ENV=development
# Allowed CORS Origin (Frontend URL)
CORS_ORIGIN=http://localhost:80
# Secret Key for signing JWTs (must be at least 32 characters long in production)
JWT_SECRET=super_secret_jwt_key_change_me_in_production
# JWT expiration duration
JWT_EXPIRES_IN=24h
# Redis Connection String
REDIS_URL=redis://127.0.0.1:6379

# 3. AI PIPELINE / WORKER CONFIGURATION
# Groq API Key for the AI generation worker
GROQ_API_KEY=gsk_your_groq_api_key_here
